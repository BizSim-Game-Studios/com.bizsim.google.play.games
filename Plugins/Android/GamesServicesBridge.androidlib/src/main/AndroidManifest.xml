<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- C5.2 predictive back gesture (Android 14+ / API 34+).
         All PGS v2 dialogs (Auth, Achievements, Leaderboards, Saved Games,
         Events, Player Stats) are system-managed and handle predictive-back
         animations internally. Declared explicitly per
         2026-04-17-enterprise-quality-bar 06-conventions/05-predictive-back-audit.md.
         Consumer app-level android:enableOnBackInvokedCallback wins on
         manifest-merger conflict. -->
    <application
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="33" />

</manifest>
